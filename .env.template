# Tushare API token (get from https://tushare.pro)
TUSHARE_TOKEN=your_token_here

# Capital (RMB)
TOTAL_CAPITAL=100000
TRADING_CAPITAL=90000
MAX_POSITIONS=5

# Strategy: ETF Trend (MA / ADX)
MA_FAST=20
MA_SLOW=60
ADX_THRESHOLD=20

# Execution
SLIPPAGE_BPS=5
COMMISSION_RATE=0.00025
ORDER_TIMEOUT_SECONDS=30
MAX_RETRIES=3

# Risk
MAX_SINGLE_DAY_DRAWDOWN_PCT=0.02
MAX_CONSECUTIVE_FAILURES=3

# WeChat Work webhook URL for critical alerts (optional)
WECHAT_WEBHOOK_URL=

# Stop-loss (0 = disabled, e.g. 10 = sell when -10% from avg cost)
STOP_LOSS_PCT=0
MONTHLY_MAX_DRAWDOWN_PCT=0.05
CONSECUTIVE_LOSS_LIMIT=5

# ============================================================
# Multi-Indicator Entry (weighted scoring)
# ============================================================
MA_LONG=120
BB_PERIOD=20
BB_STD=2.0
VOLUME_SURGE_MULTIPLIER=1.5
ADX_ENTRY_THRESHOLD=25
DI_DIFF_THRESHOLD=15
RSI_PERIOD=14
RSI_OVERBOUGHT=80

# Weighted scoring (weights must sum to ~1.0)
ENTRY_SCORE_THRESHOLD=55
ENTRY_WEIGHT_MA=0.25
ENTRY_WEIGHT_ADX=0.25
ENTRY_WEIGHT_BB=0.20
ENTRY_WEIGHT_VOL=0.20
ENTRY_WEIGHT_MKT=0.10

# ============================================================
# Exit Logic
# ============================================================
ATR_PERIOD=14
ATR_TRAILING_MULTIPLIER=2.0
ATR_TIGHTEN_MULTIPLIER=1.5

# Exit feature toggles
ATR_TRAILING_STOP_ENABLED=true
TIME_STOP_ENABLED=false
VOLATILITY_STOP_ENABLED=false
RSI_EXIT_ENABLED=false

# Time-based exits (days held)
TIME_STOP_DAYS_REDUCE=40
TIME_STOP_DAYS_EXIT=60

# ============================================================
# Market Defenses
# ============================================================

# Gap Risk (T+1 trap detection)
GAP_RISK_CHECK_ENABLED=true
GAP_RISK_THRESHOLD_PCT=5.0

# National Team intervention detection
NT_INTERVENTION_DETECTION_ENABLED=true
NT_VOLUME_SIGMA_THRESHOLD=3.0
NT_VOLUME_LOOKBACK_DAYS=60
NT_POLICY_EXIT_TIGHTEN=0.7

# T+1 settlement (A-share)
SETTLEMENT_LAG_DAYS=1

# Market Environment Filter
MARKET_ADX_THRESHOLD=20
DEFENSE_MODE_POSITION_PCT=0.20
INDEX_SMA_LONG=120

# ============================================================
# PE-Band Dynamic Allocation
# ============================================================
PE_BAND_ENABLED=false
PE_BAND_SOURCE_INDEX=000300.SH
PE_BAND_WINDOW_YEARS=10
PE_BAND_EQUITY_MAX=0.80
PE_BAND_EQUITY_MIN=0.20
PE_BAND_EQUITY_ETF=510300
PE_BAND_BOND_ETF=511880
PE_BAND_GOLD_ETF=518880
PE_BAND_GOLD_FIXED_PCT=0.10
